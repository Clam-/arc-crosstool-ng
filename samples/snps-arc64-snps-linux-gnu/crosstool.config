CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="arc64-snps-linux-gnu"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_ARC=y
CT_ARCH_64=y
CT_TARGET_CFLAGS="-g -O2 -ffunction-sections -fdata-sections"
# CT_SHOW_CT_VERSION is not set
CT_TOOLCHAIN_PKGVERSION="ARCv3 Linux glibc toolchain - build 10504"
CT_TARGET_VENDOR="snps"
CT_TARGET_ALIAS_SED_EXPR="s/${CT_TARGET_VENDOR}-//"
CT_TARGET_ALIAS="arc64-linux"
# CT_TOOLCHAIN_CMAKE_TOOLCHAIN_FILE is not set
CT_KERNEL_LINUX=y
CT_LINUX_SRC_DEVEL=y
CT_LINUX_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/linux.git"
CT_LINUX_DEVEL_REVISION="c45ffc99396bcb993013b8da095d68d7d139557e"
CT_BINUTILS_SRC_DEVEL=y
CT_BINUTILS_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/binutils-gdb.git"
CT_BINUTILS_DEVEL_REVISION="033866bd92cfd6d45d0651da2086da14b1a0fd2a"
CT_GLIBC_SRC_DEVEL=y
CT_GLIBC_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/glibc.git"
CT_GLIBC_DEVEL_REVISION="cf3a3b0d4ac0cc7c476b56a85b66b5921884a266"
CT_GLIBC_EXTRA_CONFIG_ARRAY="--disable-werror"
CT_GCC_SRC_DEVEL=y
CT_GCC_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/gcc.git"
CT_GCC_DEVEL_REVISION="544ca304b8222b5bd98776778e3d48c6a7ec2436"
CT_CC_GCC_EXTRA_CONFIG_ARRAY="--with-gnu-as --with-gnu-ld"
# CT_CC_GCC_USE_GRAPHITE is not set
# CT_CC_GCC_ENABLE_TARGET_OPTSPACE is not set
CT_CC_LANG_CXX=y
CT_CC_LANG_FORTRAN=y
CT_DEBUG_GDB=y
CT_GDB_SRC_DEVEL=y
CT_GDB_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/binutils-gdb.git"
CT_GDB_DEVEL_REVISION="1508b5c43f688d8ccc7d89fd3f3eb0b3804974b3"
# CT_GDB_CROSS_PYTHON is not set
