CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="riscv64-unknown-elf"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_RISCV=y
CT_MULTILIB=y
CT_ARCH_64=y
CT_ARCH_ARCH="rv64gc"
CT_ARCH_ABI="lp64d"
CT_TARGET_CFLAGS="-g -O2"
# CT_SHOW_CT_VERSION is not set
CT_TOOLCHAIN_PKGVERSION="RISC-V elf toolchain - build 10504"
CT_TARGET_VENDOR="snps"
CT_TARGET_ALIAS="riscv64-elf"
# CT_TOOLCHAIN_CMAKE_TOOLCHAIN_FILE is not set
CT_BINUTILS_SRC_DEVEL=y
CT_BINUTILS_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/binutils-gdb.git"
CT_BINUTILS_DEVEL_REVISION="033866bd92cfd6d45d0651da2086da14b1a0fd2a"
CT_NEWLIB_SRC_DEVEL=y
CT_NEWLIB_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/newlib.git"
CT_NEWLIB_DEVEL_REVISION="5ac69900333204f93f6e209e391bb1d3c1ba9874"
CT_LIBC_NEWLIB_TARGET_CFLAGS="-ffunction-sections -fdata-sections"
CT_LIBC_NEWLIB_IO_C99FMT=y
CT_LIBC_NEWLIB_IO_LL=y
CT_LIBC_NEWLIB_IO_FLOAT=y
CT_LIBC_NEWLIB_IO_LDBL=y
CT_LIBC_NEWLIB_REGISTER_FINI=y
# CT_LIBC_NEWLIB_ENABLE_TARGET_OPTSPACE is not set
CT_GCC_SRC_DEVEL=y
CT_GCC_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/gcc.git"
CT_GCC_DEVEL_REVISION="544ca304b8222b5bd98776778e3d48c6a7ec2436"
CT_GCC_V_13=y
CT_CC_GCC_CONFIG_TLS=y
# CT_CC_GCC_ENABLE_TARGET_OPTSPACE is not set
# CT_CC_GCC_TM_CLONE_REGISTRY is not set
CT_CC_LANG_CXX=y
CT_DEBUG_GDB=y
CT_GDB_SRC_DEVEL=y
CT_GDB_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/binutils-gdb.git"
CT_GDB_DEVEL_REVISION="1508b5c43f688d8ccc7d89fd3f3eb0b3804974b3"
# CT_GDB_CROSS_PYTHON is not set
CT_COMP_LIBS_NEWLIB_NANO=y
CT_NEWLIB_NANO_SRC_DEVEL=y
CT_NEWLIB_NANO_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/newlib.git"
CT_NEWLIB_NANO_DEVEL_REVISION="5ac69900333204f93f6e209e391bb1d3c1ba9874"
CT_LIBC_NEWLIB_NANO_TARGET_CFLAGS="-ffunction-sections -fdata-sections"
CT_LIBC_NEWLIB_NANO_IO_FLOAT=y
# CT_LIBC_NEWLIB_NANO_FVWRITE_IN_STREAMIO is not set
# CT_LIBC_NEWLIB_NANO_MULTITHREAD is not set
