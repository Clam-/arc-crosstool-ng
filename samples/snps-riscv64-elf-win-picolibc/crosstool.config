CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="riscv64-elf-win-picolibc"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_RISCV=y
CT_MULTILIB=y
CT_ARCH_64=y
CT_ARCH_ARCH="rv64gc"
CT_ARCH_ABI="lp64d"
CT_TARGET_CFLAGS="-g -O3 -ftls-model=local-exec"
# CT_SHOW_CT_VERSION is not set
CT_TOOLCHAIN_PKGVERSION="RISC-V elf picolibc toolchain - build 10504"
CT_TARGET_VENDOR="snps"
CT_TARGET_ALIAS="riscv64-elf"
CT_CANADIAN=y
CT_HOST="i686-w64-mingw32"
# CT_TOOLCHAIN_CMAKE_TOOLCHAIN_FILE is not set
CT_BINUTILS_SRC_DEVEL=y
CT_BINUTILS_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/binutils-gdb.git"
CT_BINUTILS_DEVEL_REVISION="033866bd92cfd6d45d0651da2086da14b1a0fd2a"
CT_LIBC_PICOLIBC=y
CT_PICOLIBC_SRC_DEVEL=y
CT_PICOLIBC_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/picolibc.git"
CT_PICOLIBC_DEVEL_REVISION="cf67d21967f393369bb96c3493343ea39c023df9"
CT_LIBC_PICOLIBC_IO_LL=y
CT_LIBC_PICOLIBC_EXTRA_SECTIONS=y
CT_LIBC_PICOLIBC_OBSOLETE_FLOAT=y
CT_LIBC_PICOLIBC_EXTRA_CONFIG_ARRAY="-Dio-long-double=true -Dio-percent-b=true -Dprintf-percent-n=true -Dfast-bufio=true -Dmb-capable=true -Dio-wchar=true -Dposix-console=true -Dnewlib-obsolete-math=false -Dwant-math-errno=true -Dassert-verbose=true -Doptimization=3"
CT_LIBC_PICOLIBC_DEFAULT_FLASH_ADDR="0x00000000"
CT_LIBC_PICOLIBC_DEFAULT_FLASH_SIZE="128K"
CT_LIBC_PICOLIBC_DEFAULT_RAM_ADDR="0x40000000"
CT_LIBC_PICOLIBC_DEFAULT_RAM_SIZE="128K"
CT_GCC_SRC_DEVEL=y
CT_GCC_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/gcc.git"
CT_GCC_DEVEL_REVISION="544ca304b8222b5bd98776778e3d48c6a7ec2436"
CT_GCC_V_13=y
CT_CC_GCC_CONFIG_TLS=y
# CT_CC_GCC_USE_LTO is not set
# CT_CC_GCC_ENABLE_TARGET_OPTSPACE is not set
# CT_CC_GCC_TM_CLONE_REGISTRY is not set
CT_CC_LANG_CXX=y
CT_DEBUG_GDB=y
CT_GDB_SRC_DEVEL=y
CT_GDB_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/binutils-gdb.git"
CT_GDB_DEVEL_REVISION="1508b5c43f688d8ccc7d89fd3f3eb0b3804974b3"
CT_NCURSES_V_6_4=y
CT_COMP_LIBS_PICOLIBC_NANO=y
CT_PICOLIBC_NANO_SRC_DEVEL=y
CT_PICOLIBC_NANO_DEVEL_URL="https://github.com/foss-for-synopsys-dwc-arc-processors/picolibc.git"
CT_PICOLIBC_NANO_DEVEL_REVISION="cf67d21967f393369bb96c3493343ea39c023df9"
CT_LIBC_PICOLIBC_NANO_TARGET_CFLAGS="-Os -msave-restore"
CT_LIBC_PICOLIBC_NANO_IO_C99FMT=y
CT_LIBC_PICOLIBC_NANO_EXTRA_SECTIONS=y
CT_LIBC_PICOLIBC_NANO_OBSOLETE_FLOAT=y
CT_LIBC_PICOLIBC_NANO_EXTRA_CONFIG_ARRAY="-Dposix-console=true -Dnewlib-obsolete-math=false -Dwant-math-errno=true -Dassert-verbose=true -Doptimization=s"
CT_LIBC_PICOLIBC_NANO_GCC_LIBSTDCXX_TARGET_CXXFLAGS="-fno-exceptions -msave-restore -g"
# CT_LIBICONV_NEEDED is not set
# CT_GETTEXT_NEEDED is not set
